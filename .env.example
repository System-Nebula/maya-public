# Copy to .env (gitignored) and edit, or use .envrc with direnv.
# Gateway + ingest read DATABASE_URL via maya_db.connection.get_engine.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/maya_public

# Gateway port — defaults to 8090 (8080 is commonly taken by AdGuard).
PORT=8090

# --- Discord bot + ComfyUI arena (apps/maya-bot) ---

DISCORD_TOKEN=
# Self-host bypass: skip portal OAuth (default on in bot README)
IMAGINE_SKIP_PORTAL_LINK=1
MAYA_DEV_PORTAL_USER_ID=local-dev
TEST_GUILD_ID=
COMFYUI_API_URL=http://localhost:3000
COMFYUI_WEBHOOK_SECRET=
MAYA_IMAGE_ROOT=./data/outputs/maya-image
MAYA_ARENA_PAIR=z-image-turbo-t2i,krea2-turbo-t2i
MAYA_ARENA_SIZE=512x512
HF_TOKEN=

# Forge imagine UAT — fake provider (default CI / DB-free smoke)
MAYA_FAKE_COMFY=1

# Forge imagine UAT — integrated arena (local Postgres + fake Comfy)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/maya_public
# MAYA_FAKE_COMFY=1
# MAYA_IMAGE_ROOT=./data/outputs/maya-image

# Forge imagine UAT — real ComfyUI/GPU acceptance (manual; do not enable in CI)
# MAYA_FAKE_COMFY=
# COMFYUI_API_URL=http://localhost:3000
# HF_TOKEN=


# YouTube Data API enrichment + comment fetch (else Atom-feed-only path).
YOUTUBE_API_KEY=

# maya-ingest embed_batch flow.
NOMIC_API_KEY=
EMBED_BACKEND=local

# GitHub release-diff analysis (raises rate limit when set).
GITHUB_TOKEN=

# LLM analysis for release diffs (OpenAI-compatible API).
LLM_PROVIDER=lmstudio
LLM_API_KEY=
LLM_MODEL=local-model
LLM_BASE_URL=http://localhost:1234/v1

# Music ontology graph DSN (read-only for discover ranker; ingest upserts releases).
MAYA_ONTOLOGY_DSN=postgresql://postgres:postgres@localhost:5433/maya_public

# Parent Workspace root for lib/sources (Beatport, Discogs, Bandcamp adapters).
MAYA_WORKSPACE_ROOT=

# Soulseek acquisition (slskd) — required by slskd_search + music_query_cli.
SLSKD_HOST=http://localhost:5030
SLSKD_API_KEY=

# Discogs API token — release tracklist ingest.
DISCOGS_TOKEN=
