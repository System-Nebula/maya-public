# Copy to .env (gitignored) and edit, or use .envrc with direnv.
# Gateway + ingest read DATABASE_URL via maya_db.connection.get_engine.
DATABASE_URL=postgresql+asyncpg://maya:maya@localhost:5433/maya_public

# Gateway port — defaults to 8090 (8080 is commonly taken by AdGuard).
PORT=8090
MAYA_GATEWAY_URL=http://127.0.0.1:8090

# --- Gateway auth (invite-gated registration + SSO) ---

# Set to 0 to require login; default 1 preserves legacy operator_id=local
AUTH_DISABLED=1
SESSION_SECRET=
# development enables warby@localhost / admin@localhost email validation
ENV=development

# Optional single-code fallback when invite_codes table is empty
MAYA_REGISTRATION_INVITE_CODE=
MAYA_LEGACY_OPERATOR_ID=local
MAYA_SEED_INVITE_CODE=dev-invite
MAYA_SEED_WARBY_EMAIL=warby@localhost
MAYA_SEED_WARBY_PASSWORD=
MAYA_SEED_ADMIN_EMAIL=admin@localhost
MAYA_SEED_ADMIN_PASSWORD=
# Optional shared password for make auth-seed (falls back to per-user vars above)
MAYA_SEED_DEV_PASSWORD=

# OAuth — copy from ~/Workspace/start-page/.env (Google) and ~/Workspace/.env (Discord app ID).
# Paste DISCORD_CLIENT_SECRET from Discord Developer Portal → OAuth2 (not in repo).
# Add redirect URIs below in Google Cloud Console and Discord Developer Portal.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8090/auth/google/callback

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://127.0.0.1:8090/gateway/connectors/discord/callback
DISCORD_GUILD_ID=
DISCORD_VERIFIED_ROLE_ID=

# Portal URL for Discord bot (same host as gateway when unified)
MAYA_PUBLIC_URL=http://localhost:8090

# --- Discord bot + ComfyUI arena (apps/maya-bot) ---

DISCORD_TOKEN=
# Set IMAGINE_SKIP_PORTAL_LINK=0 when auth is enabled and Discord linking is configured
IMAGINE_SKIP_PORTAL_LINK=1
MAYA_DEV_PORTAL_USER_ID=local-dev
TEST_GUILD_ID=
COMFYUI_API_URL=http://localhost:3000
COMFYUI_WEBHOOK_SECRET=
MAYA_IMAGE_ROOT=./data/outputs/maya-image
MAYA_ARENA_PAIR=z-image-turbo-t2i,krea2-turbo-t2i
MAYA_ARENA_SIZE=512x512
HF_TOKEN=

# Forge imagine UAT — fake provider (default CI / DB-free smoke)
MAYA_FAKE_COMFY=1

# Forge imagine UAT — integrated arena (local Postgres + fake Comfy)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/maya_public
# MAYA_FAKE_COMFY=1
# MAYA_IMAGE_ROOT=./data/outputs/maya-image

# Forge imagine UAT — real ComfyUI/GPU acceptance (manual; do not enable in CI)
# MAYA_FAKE_COMFY=
# COMFYUI_API_URL=http://localhost:3000
# HF_TOKEN=


# YouTube Data API enrichment + comment fetch (else Atom-feed-only path).
YOUTUBE_API_KEY=

# maya-ingest embed_batch flow.
NOMIC_API_KEY=
EMBED_BACKEND=local

# GitHub release-diff analysis (raises rate limit when set).
GITHUB_TOKEN=

# LLM analysis for release diffs (OpenAI-compatible API).
LLM_PROVIDER=lmstudio
LLM_API_KEY=
LLM_MODEL=local-model
LLM_BASE_URL=http://localhost:1234/v1

# --- Gateway dictation ASR (/api/audio, packages/maya-audio) ---

# Which ASR backend drives mic dictation. "fake" (default) returns a canned transcript
# with zero GPU; "whisper" runs real local faster-whisper.
# MAYA_ASR_BACKEND=whisper
# MAYA_WHISPER_MODEL=small.en
# MAYA_WHISPER_DEVICE=cpu        # cpu (int8) or cuda (float16)
# MAYA_WHISPER_COMPUTE=int8      # override compute type if needed

# --- Voice stack (packages/maya-voice-stack) ---

# Fake stack for CI / Playwright (no GPU)
# VA_FAKE_STACK=1

# OpenRouter DeepSeek for full-stack voice runs
# VA_LLM_BASE_URL=https://openrouter.ai/api/v1
# VA_LLM_API_KEY=
# OPENROUTER_API_KEY=
# VA_LLM_MODEL=deepseek/deepseek-chat-v3-0324
# VA_LLM_DISABLE_THINKING=1

# OTEL / Langfuse agent visibility
# OTEL_EXPORTER_OTLP_ENDPOINT=https://cloud.langfuse.com/api/public/otel
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(public_key:secret_key)>
# OTEL_SERVICE_NAME=maya-voice-stack

# Music ontology graph DSN (read-only for discover ranker; ingest upserts releases).
MAYA_ONTOLOGY_DSN=postgresql://postgres:postgres@localhost:5433/maya_public

# Parent Workspace root for lib/sources (Beatport, Discogs, Bandcamp adapters).
MAYA_WORKSPACE_ROOT=

# Soulseek acquisition (slskd) — required by slskd_search + music_query_cli.
SLSKD_HOST=http://localhost:5030
SLSKD_API_KEY=

# Discogs API token — release tracklist ingest.
DISCOGS_TOKEN=
